    "tokenColors": [
        {
            "name": "Comment",
            "scope": [
                "comment",
                "punctuation.definition.comment"
            ],
            "settings": {
                "foreground": "#ffffff4f"
            }
        },
        {
            "name": "Punctuation",
            "scope": [
                "punctuation.definition",
                "punctuation.definition.quote.begin.markdown",
                "punctuation.definition.tag",
                "punctuation.section.embedded"
            ],
            "settings": {
                "foreground": "#ffffff5f"
            }
        },
        {
            "name": "String",
            "scope": [
                "string",
                "meta.embedded.assembly",
                "punctuation.definition.string"
            ],
            "settings": {
                "foreground": "#74ccaa"
            }
        },
        {
            "name": "String Tag",
            "scope": "string.tag",
            "settings": {
                "foreground": "#74ccaa"
            }
        },
        {
            "name": "String Value",
            "scope": "string.value",
            "settings": {
                "foreground": "#74ccaa"
            }
        },
        {
            "name": "String Regexp",
            "scope": "string.regexp",
            "settings": {
                "foreground": "#f6c177"
            }
        },
        {
            "name": "Constant",
            "scope": "constant.language",
            "settings": {
                "foreground": "#f6c177"
            }
        },
        {
            "name": "Constant Numeric",
            "scope": [
                "constant.numeric",
                "variable.other.enummember",
                "keyword.operator.plus.exponent",
                "keyword.operator.minus.exponent"
            ],
            "settings": {
                "foreground": "#f6c177"
            }
        },
        {
            "name": "Constant Regexp",
            "scope": "constant.regexp",
            "settings": {
                "foreground": "#f6c177"
            }
        },
        {
            "name": "Variable",
            "scope": [
                "variable",
                "meta.definition.variable.name",
                "support.variable",
                "entity.name.variable"
            ],
            "settings": {
                "foreground": "#a0a5d6"
            }
        },
        {
            "name": "Keyword",
            "scope": "keyword",
            "settings": {
                "foreground": "#ed9cc2"
            }
        },
        {
            "name": "Keyword Control",
            "scope": "keyword.control",
            "settings": {
                "foreground": "#ed9cc2"
            }
        },
        {
            "name": "Keyword Operator",
            "scope": "keyword.operator",
            "settings": {
                "foreground": "#ed9cc2"
            }
        },
        {
            "name": "Keyword Operator Special",
            "scope": [
                "keyword.operator.new",
                "keyword.operator.expression",
                "keyword.operator.cast",
                "keyword.operator.sizeof",
                "keyword.operator.alignof",
                "keyword.operator.typeid",
                "keyword.operator.alignas",
                "keyword.operator.instanceof",
                "keyword.operator.logical.python",
                "keyword.operator.wordlike"
            ],
            "settings": {
                "foreground": "#ed9cc2"
            }
        },
        {
            "name": "Keyword Other Unit",
            "scope": "keyword.other.unit",
            "settings": {
                "foreground": "#ed9cc2"
            }
        },
        {
            "name": "Storage",
            "scope": "storage",
            "settings": {
                "foreground": "#ed9cc2"
            }
        },
        {
            "name": "Storage Type",
            "scope": "storage.type",
            "settings": {
                "foreground": "#ed9cc2"
            }
        },
        {
            "name": "Storage Modifier",
            "scope": [
                "storage.modifier",
                "keyword.operator.noexcept"
            ],
            "settings": {
                "foreground": "#ed9cc2"
            }
        },
        {
            "name": "Entity Name Tag",
            "scope": [
                "entity.name.tag",
                "entity.name.tag.css",
                "support.class.component"
            ],
            "settings": {
                "foreground": "#ed9cc2"
            }
        },
        {
            "name": "Entity Name Type",
            "scope": [
                "support.class",
                "support.type",
                "entity.name.type",
                "entity.name.namespace",
                "entity.other.attribute",
                "entity.name.scope-resolution",
                "entity.name.class"
            ],
            "settings": {
                "foreground": "#f3a580"
            }
        },
        {
            "name": "Entity Other Attribute",
            "scope": "entity.other.attribute-name",
            "settings": {
                "foreground": "#5fb5be"
            }
        },
        {
            "name": "Entity Other Attribute CSS",
            "scope": [
                "entity.other.attribute-name.class.css",
                "entity.other.attribute-name.class.mixin.css",
                "entity.other.attribute-name.id.css",
                "entity.other.attribute-name.parent-selector.css",
                "entity.other.attribute-name.pseudo-class.css",
                "entity.other.attribute-name.pseudo-element.css",
                "source.css.less entity.other.attribute-name.id",
                "entity.other.attribute-name.scss"
            ],
            "settings": {
                "foreground": "#5fb5be"
            }
        },
        {
            "name": "Function Declaration",
            "scope": [
                "entity.name.function",
                "support.function",
                "support.constant.handlebars",
                "entity.name.operator.custom-literal"
            ],
            "settings": {
                "foreground": "#5fb5be"
            }
        },
        {
            "name": "Invalid",
            "scope": "invalid",
            "settings": {
                "foreground": "#ff8787"
            }
        },
        {
            "name": "Invalid Deprecated",
            "scope": "invalid.deprecated",
            "settings": {
                "foreground": "#ff8787"
            }
        },
        {
            "name": "Markup Heading",
            "scope": "markup.heading",
            "settings": {
                "foreground": "#74ccaa",
                "fontStyle": "bold"
            }
        },
        {
            "name": "Markup Bold",
            "scope": "markup.bold",
            "settings": {
                "foreground": "#a0a5d6",
                "fontStyle": "bold"
            }
        },
        {
            "name": "Markup Italic",
            "scope": "markup.italic",
            "settings": {
                "foreground": "#a0a5d6",
                "fontStyle": "italic"
            }
        },
        {
            "name": "Markup Inserted",
            "scope": "markup.inserted",
            "settings": {
                "foreground": "#74ccaa"
            }
        },
        {
            "name": "Markup Deleted",
            "scope": "markup.deleted",
            "settings": {
                "foreground": "#ff8787"
            }
        },
        {
            "name": "Markup Changed",
            "scope": "markup.changed",
            "settings": {
                "foreground": "#5fb5be"
            }
        },
        {
            "name": "Markup Quote",
            "scope": "markup.quote",
            "settings": {
                "foreground": "#a0a0a0",
                "fontStyle": "italic"
            }
        },
        {
            "name": "Markup Link",
            "scope": "string.other.link",
            "settings": {
                "foreground": "#5fb5be"
            }
        },
        {
            "name": "Markup Code",
            "scope": "markup.inline.raw",
            "settings": {
                "foreground": "#f6c177"
            }
        },
        {
            "name": "Markup Underline",
            "scope": "markup.underline",
            "settings": {
                "fontStyle": "underline"
            }
        },
        {
            "name": "Markup Strikethrough",
            "scope": "markup.strikethrough",
            "settings": {
                "fontStyle": "strikethrough"
            }
        },
        {
            "name": "Language This",
            "scope": "variable.language",
            "settings": {
                "fontStyle": "italic",
                "foreground": "#ed9cc2"
            }
        },
        {
            "name": "Meta Template Expression",
            "scope": "meta.template.expression",
            "settings": {
                "foreground": "#d4d4d4"
            }
        },
        {
            "name": "Variable CSS",
            "scope": [
                "support.type.vendored.property-name",
                "support.type.property-name",
                "variable.css",
                "variable.scss",
                "variable.other.less",
                "source.coffee.embedded"
            ],
            "settings": {
                "foreground": "#a0a5d6"
            }
        },
        {
            "name": "JSON Keys",
            "scope": "meta.object-literal.key",
            "settings": {
                "foreground": "#a0a5d6"
            }
        }
    ],
    "semanticTokenColors": {
        "newOperator": "#ed9cc2",
        "stringLiteral": "#74ccaa",
        "customLiteral": "#f6c177",
        "numberLiteral": "#f6c177"
    }
}