    "tokenColors": [
        {
            "name": "Comment",
            "scope": [
                "comment",
                "punctuation.definition.comment"
            ],
            "settings": {
                "foreground": "#ffffff4f",
                "fontStyle": "italic"
            }
        },
        {
            "name": "String",
            "scope": "string",
            "settings": {
                "foreground": "#74ccaa"
            }
        },
        {
            "name": "Constant",
            "scope": "constant",
            "settings": {
                "foreground": "#f6c177"
            }
        },
        {
            "name": "Variable",
            "scope": "variable",
            "settings": {
                "foreground": "#d4d4d4",
                "fontStyle": ""
            }
        },
        {
            "name": "Keyword",
            "scope": "keyword",
            "settings": {
                "foreground": "#ed9cc2"
            }
        },
        {
            "name": "Storage",
            "scope": "storage",
            "settings": {
                "foreground": "#ed9cc2"
            }
        },
        {
            "name": "Entity Name Type",
            "scope": "entity.name.type",
            "settings": {
                "foreground": "#f3a580",
                "fontStyle": "underline"
            }
        },
        {
            "name": "Entity Name Function",
            "scope": "entity.name.function",
            "settings": {
                "foreground": "#5fb5be"
            }
        },
        {
            "name": "Support Function",
            "scope": "support.function",
            "settings": {
                "foreground": "#ed9cc2"
            }
        },
        {
            "name": "Support Class",
            "scope": "support.class",
            "settings": {
                "foreground": "#f3a580"
            }
        },
        {
            "name": "Support Type",
            "scope": "support.type",
            "settings": {
                "foreground": "#f3a580",
                "fontStyle": ""
            }
        },
        {
            "name": "Tag",
            "scope": "tag",
            "settings": {
                "foreground": "#ed9cc2"
            }
        },
        {
            "name": "Tag Attribute",
            "scope": "tag.attribute",
            "settings": {
                "foreground": "#5fb5be"
            }
        },
        {
            "name": "Invalid",
            "scope": "invalid",
            "settings": {
                "foreground": "#ff8787"
            }
        },
        {
            "name": "Invalid Deprecated",
            "scope": "invalid.deprecated",
            "settings": {
                "foreground": "#ff8787"
            }
        },
        {
            "name": "Markup Heading",
            "scope": "markup.heading",
            "settings": {
                "foreground": "#5fb5be",
                "fontStyle": "bold"
            }
        },
        {
            "name": "Markup Bold",
            "scope": "markup.bold",
            "settings": {
                "foreground": "#a0a5d6",
                "fontStyle": "bold"
            }
        },
        {
            "name": "Markup Italic",
            "scope": "markup.italic",
            "settings": {
                "foreground": "#a0a5d6",
                "fontStyle": "italic"
            }
        },
        {
            "name": "Markup Inserted",
            "scope": "markup.inserted",
            "settings": {
                "foreground": "#74ccaa"
            }
        },
        {
            "name": "Markup Deleted",
            "scope": "markup.deleted",
            "settings": {
                "foreground": "#ff8787"
            }
        },
        {
            "name": "Markup Changed",
            "scope": "markup.changed",
            "settings": {
                "foreground": "#5fb5be"
            }
        },
        {
            "name": "Markup Quote",
            "scope": "markup.quote",
            "settings": {
                "foreground": "#a0a0a0",
                "fontStyle": "italic"
            }
        },
        {
            "name": "Markup Link",
            "scope": "markup.link",
            "settings": {
                "foreground": "#5fb5be",
                "fontStyle": "underline"
            }
        },
        {
            "name": "Markup Code",
            "scope": "markup.inline.raw",
            "settings": {
                "foreground": "#f6c177"
            }
        }
    ]
}