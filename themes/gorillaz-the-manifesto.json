    "tokenColors": [
        {
            "name": "Comment",
            "scope": [
                "comment",
                "punctuation.definition.comment"
            ],
            "settings": {
                "foreground": "#75797f",
                "fontStyle": "italic"
            }
        },
        {
            "name": "String",
            "scope": "string",
            "settings": {
                "foreground": "#8A9A7B"
            }
        },
        {
            "name": "Constant",
            "scope": "constant",
            "settings": {
                "foreground": "#B6927B"
            }
        },
        {
            "name": "Variable",
            "scope": "variable",
            "settings": {
                "foreground": "#c5c9c7",
                "fontStyle": ""
            }
        },
        {
            "name": "Keyword",
            "scope": "keyword",
            "settings": {
                "foreground": "#8992A7",
                "fontStyle": "bold"
            }
        },
        {
            "name": "Storage",
            "scope": "storage",
            "settings": {
                "foreground": "#8992A7"
            }
        },
        {
            "name": "Entity Name Type",
            "scope": "entity.name.type",
            "settings": {
                "foreground": "#C4B28A",
                "fontStyle": "underline"
            }
        },
        {
            "name": "Entity Name Function",
            "scope": "entity.name.function",
            "settings": {
                "foreground": "#C4746E"
            }
        },
        {
            "name": "Support Function",
            "scope": "support.function",
            "settings": {
                "foreground": "#8992A7"
            }
        },
        {
            "name": "Support Class",
            "scope": "support.class",
            "settings": {
                "foreground": "#C4B28A"
            }
        },
        {
            "name": "Support Type",
            "scope": "support.type",
            "settings": {
                "foreground": "#C4B28A",
                "fontStyle": ""
            }
        },
        {
            "name": "Tag",
            "scope": "tag",
            "settings": {
                "foreground": "#C4B28A"
            }
        },
        {
            "name": "Tag Attribute",
            "scope": "tag.attribute",
            "settings": {
                "foreground": "#C4746E"
            }
        },
        {
            "name": "Invalid",
            "scope": "invalid",
            "settings": {
                "foreground": "#E46876"
            }
        },
        {
            "name": "Invalid Deprecated",
            "scope": "invalid.deprecated",
            "settings": {
                "foreground": "#E46876"
            }
        },
        {
            "name": "Markup Heading",
            "scope": "markup.heading",
            "settings": {
                "foreground": "#C4B28A",
                "fontStyle": "bold"
            }
        },
        {
            "name": "Markup Bold",
            "scope": "markup.bold",
            "settings": {
                "foreground": "#C4746E",
                "fontStyle": "bold"
            }
        },
        {
            "name": "Markup Italic",
            "scope": "markup.italic",
            "settings": {
                "foreground": "#E46876",
                "fontStyle": "italic"
            }
        },
        {
            "name": "Markup Inserted",
            "scope": "markup.inserted",
            "settings": {
                "foreground": "#C4B28A"
            }
        },
        {
            "name": "Markup Deleted",
            "scope": "markup.deleted",
            "settings": {
                "foreground": "#E46876"
            }
        },
        {
            "name": "Markup Changed",
            "scope": "markup.changed",
            "settings": {
                "foreground": "#DCA561"
            }
        },
        {
            "name": "Markup Quote",
            "scope": "markup.quote",
            "settings": {
                "foreground": "#9E9B93",
                "fontStyle": "italic"
            }
        },
        {
            "name": "Markup Link",
            "scope": "markup.link",
            "settings": {
                "foreground": "#8992A7",
                "fontStyle": "underline"
            }
        },
        {
            "name": "Markup Code",
            "scope": "markup.inline.raw",
            "settings": {
                "foreground": "#C4B28A"
            }
        }
    ]
}