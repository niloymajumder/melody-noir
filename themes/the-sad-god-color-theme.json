  "tokenColors": [
    {
      "name": "Text",
      "scope": [
        "meta.embedded",
        "source.groovy.embedded",
        "string meta.image.inline.markdown"
      ],
      "settings": {
        "foreground": "#C8D0DC"
      }
    },
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#4E5668",
        "fontStyle": "italic"
      }
    },
    {
      "name": "String",
